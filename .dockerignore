# Dependency and build output are recreated inside the image.
node_modules
.next
out
dist
coverage

# Never send repository metadata, local configuration, or secrets to the build daemon.
.git
.github
.gitignore
.dockerignore
.env
.env.*
.npmrc

# Documentation and deployment files are not inputs to `next build`.
docs
**/*.md
LICENSE
Dockerfile*
docker-compose*.yml

# Local caches, reports, editor state, and generated archives.
.cache
.eslintcache
*.tsbuildinfo
*.log
*.lcov
*.tgz
report.*.json
.idea
.serena
.vscode
.DS_Store
.jsr
.jsrrc

# Project-local helper/output directories.
.setup.sh
.build.sh
examples/input
examples/output
html
